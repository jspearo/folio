# === IMAP (citanie uctovnych emailov) ===
IMAP_HOST=mail.example.sk
IMAP_PORT=993
IMAP_USERNAME=user@example.eu
IMAP_PASSWORD=__FILL_ME__

# === SMTP (odoslanie emailu uctovnikovi) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=user@example.eu
SMTP_PASSWORD=__FILL_ME_APP_PASSWORD__

# === Nextcloud ===
NC_BASE_URL=https://nextcloud.example.eu
NC_USERNAME=jd
NC_APP_PASSWORD=__FILL_ME_NEXTCLOUD_APP_PASSWORD__

# === Lokalny drop folder ===
# Toto je lokalny folder ktory Nextcloud klient synchronizuje do cloudu.
# Mapovanie napr.: ACCOUNTANT_DROP=/home/user/Nextcloud/Uctovnictvo
# zodpoveda Nextcloud ceste /Uctovnictvo/<file>
ACCOUNTANT_DROP=c:\opt\prj\aip\foliodata
NC_REMOTE_PREFIX=/Uctovnictvo

# === Email uctovnika ===
UCTOVNIK_EMAIL=uctovnik@example.sk

# === Heslo na sifrovanie 7z (min. 16 znakov) ===
ACC_ZIP_PASSWORD=__FILL_ME_MIN_16_CHARS__

# === Bankove sparovanie (volitelne, krok 5) ===
# Heslo na dekrypciu PDF vypisov (typicky pevne stanovene v internet bankingu)
BANK_PDF_PASSWORD=__FILL_ME__
# Volitelne: whitelist email odosielatelov, ked je vypisov viac z roznych adries
BANK_SENDER_WHITELIST=noreply@bank.sk,statements@bank2.sk
# Per-bank override (pouzi --bank tatra resp. --bank vub v decrypt skripte):
# BANK_PDF_PASSWORD_TATRA=...
# BANK_PDF_PASSWORD_VUB=...

# === Setup ===
# Po vyplneni hodnot tento subor preves cez DPAPI sifrovanie:
#     ./tools/env-protect.ps1 -RemovePlain
# Vytvori .env.enc a zmaze plaintext .env.
# Editovanie do buducnosti: ./tools/env-edit.ps1
